@@ -0,0 +1,39 @@
+package server_test
+
+import (
+	"testing"
+
+	"github.com/Mic92/niks3/server"
+)
+
+// TestUseSimpleUpload pins the NAR upload-strategy decision: small NARs take a
+// single presigned PUT (cheap b2_upload_file) and only larger/unknown-size NARs
+// pay for an S3 multipart upload (whose b2_finish_large_file B2 throttles hard).
+func TestUseSimpleUpload(t *testing.T) {
+	t.Parallel()
+
+	const mib = 1 << 20
+
+	tests := []struct {
+		name    string
+		narSize uint64
+		want    bool
+	}{
+		{"unknown size uses multipart", 0, false},
+		{"tiny NAR uses simple", 248, true},
+		{"1 MiB uses simple", 1 * mib, true},
+		{"exactly at threshold uses simple", server.SimpleUploadMaxNarSize, true},
+		{"one byte over threshold uses multipart", server.SimpleUploadMaxNarSize + 1, false},
+		{"large NAR uses multipart", 500 * mib, false},
+	}
+
+	for _, tc := range tests {
+		t.Run(tc.name, func(t *testing.T) {
+			t.Parallel()
+
+			if got := server.UseSimpleUpload(tc.narSize); got != tc.want {
+				t.Errorf("UseSimpleUpload(%d) = %v, want %v", tc.narSize, got, tc.want)
+			}
+		})
+	}
+}
