diff --git a/server/pending_multipart.go b/server/pending_multipart.go
index 2981c0d..12c5180 100644
--- a/server/pending_multipart.go
+++ b/server/pending_multipart.go
@@ -12,8 +12,18 @@ import (
 
 const (
 	multipartPartSize = 10 * 1024 * 1024 // 10MB parts
+
+	// NARs at or below one part skip multipart, whose per-object finish call
+	// (b2_finish_large_file) B2 throttles hard where a single PutObject does not.
+	simpleUploadMaxNarSize = multipartPartSize
 )
 
+// useSimpleUpload reports whether a NAR of the given uncompressed size uses a
+// single presigned PUT rather than multipart. Size 0 (unknown) uses multipart.
+func useSimpleUpload(narSize uint64) bool {
+	return narSize > 0 && narSize <= simpleUploadMaxNarSize
+}
