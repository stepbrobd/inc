--- /dev/null
+++ b/client/nar_simple_upload_test.go
@@ -0,0 +1,96 @@
+package client_test
+
+import (
+	"io"
+	"net/http"
+	"net/http/httptest"
+	"os"
+	"path/filepath"
+	"strings"
+	"sync/atomic"
+	"testing"
+
+	"github.com/Mic92/niks3/client"
+	"github.com/klauspost/compress/zstd"
+)
+
+// TestCompressAndSimpleUploadNAR pins the small-NAR fast path: a single presigned
+// PUT, no multipart lifecycle, and crucially the object is stored as opaque zstd
+// bytes WITHOUT a Content-Encoding header. nix-daemon decompresses the NAR itself
+// per the narinfo Compression field, so a Content-Encoding would cause the read
+// path to transparently decode and corrupt the result. It must also return the
+// directory listing produced during serialization.
+func TestCompressAndSimpleUploadNAR(t *testing.T) {
+	t.Parallel()
+
+	storePath := t.TempDir()
+	if err := os.WriteFile(filepath.Join(storePath, "hello"), []byte("world"), 0o644); err != nil {
+		t.Fatalf("write: %v", err)
+	}
+
+	var (
+		puts        atomic.Int32
+		gotMethod   string
+		gotEncoding string
+		gotType     string
+		gotBody     []byte
+	)
+
+	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		puts.Add(1)
+		gotMethod = r.Method
+		gotEncoding = r.Header.Get("Content-Encoding")
+		gotType = r.Header.Get("Content-Type")
+		gotBody, _ = io.ReadAll(r.Body)
+		w.WriteHeader(http.StatusOK)
+	}))
+	defer srv.Close()
+
+	c := client.NewTestClient(srv.Client(), client.RetryConfig{})
+
+	listing, err := c.CompressAndSimpleUploadNAR(
+		t.Context(), storePath, 11, srv.URL+"/nar/abc.nar.zst", "nar/abc.nar.zst",
+	)
+	if err != nil {
+		t.Fatalf("CompressAndSimpleUploadNAR: %v", err)
+	}
+
+	if listing == nil {
+		t.Fatal("expected a directory listing, got nil")
+	}
+
+	if n := puts.Load(); n != 1 {
+		t.Fatalf("expected exactly 1 PUT (single simple upload), got %d", n)
+	}
+
+	if gotMethod != http.MethodPut {
+		t.Errorf("method = %q, want PUT", gotMethod)
+	}
+
+	// The NAR must be stored as opaque bytes: no Content-Encoding (nix decodes it
+	// per the narinfo), Content-Type matching the multipart part upload.
+	if gotEncoding != "" {
+		t.Errorf("Content-Encoding = %q, want empty (NAR is opaque, decoded by nix)", gotEncoding)
+	}
+
+	if gotType != "application/octet-stream" {
+		t.Errorf("Content-Type = %q, want application/octet-stream", gotType)
+	}
+
+	dec, err := zstd.NewReader(nil)
+	if err != nil {
+		t.Fatalf("zstd reader: %v", err)
+	}
+	defer dec.Close()
+
+	raw, err := dec.DecodeAll(gotBody, nil)
+	if err != nil {
+		t.Fatalf("uploaded body is not valid zstd: %v", err)
+	}
+
+	// A NAR encodes strings as an 8-byte length prefix + data, so the
+	// "nix-archive-1" magic sits at offset 8, not at the very start.
+	if !strings.Contains(string(raw), "nix-archive-1") {
+		t.Error("decompressed body is not a NAR (missing nix-archive-1 magic)")
+	}
+}
