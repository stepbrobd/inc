 use crate::nix::{Goal, Key, Profile, StorePath, CURRENT_PROFILE, SYSTEM_PROFILE};
 use crate::util::{CommandExecution, CommandExt};
 
+const ACTIVATION_TIMEOUT: Duration = Duration::from_secs(300);
+
 /// A remote machine connected over SSH.
 #[derive(Debug)]
 pub struct Ssh {
@@ -46,6 +49,120 @@ pub struct Ssh {
 #[derive(Debug, Clone, PartialEq, Eq)]
 struct BootId(String);
 
+#[derive(Debug, PartialEq, Eq)]
+enum ActivationState {
+    Running,
+    Succeeded,
+    Failed {
+        result: String,
+        exit_status: Option<i32>,
+    },
+}
+
+#[derive(Debug, PartialEq, Eq)]
+struct ActivationStatus {
+    load_state: String,
+    active_state: String,
+    sub_state: String,
+    result: String,
+    exec_main_status: Option<i32>,
+}
+
+impl ActivationStatus {
+    fn from_systemctl_show(output: &str) -> ColmenaResult<Self> {
+        let mut load_state = None;
+        let mut active_state = None;
+        let mut sub_state = None;
+        let mut result = None;
+        let mut exec_main_status = None;
+
+        for line in output.lines() {
+            if line.is_empty() {
+                continue;
+            }
+
+            let (key, value) = line
+                .split_once('=')
+                .ok_or_else(|| ColmenaError::BadOutput {
+                    output: output.to_string(),
+                })?;
+
+            match key {
+                "LoadState" => load_state = Some(value.to_string()),
+                "ActiveState" => active_state = Some(value.to_string()),
+                "SubState" => sub_state = Some(value.to_string()),
+                "Result" => result = Some(value.to_string()),
+                "ExecMainStatus" => {
+                    exec_main_status = if value.is_empty() {
+                        None
+                    } else {
+                        Some(value.parse().map_err(|_| ColmenaError::BadOutput {
+                            output: output.to_string(),
+                        })?)
+                    }
+                }
+                _ => {}
+            }
+        }
+
+        Ok(Self {
+            load_state: load_state.ok_or_else(|| ColmenaError::BadOutput {
+                output: output.to_string(),
+            })?,
+            active_state: active_state.ok_or_else(|| ColmenaError::BadOutput {
+                output: output.to_string(),
+            })?,
+            sub_state: sub_state.ok_or_else(|| ColmenaError::BadOutput {
+                output: output.to_string(),
+            })?,
+            result: result.ok_or_else(|| ColmenaError::BadOutput {
+                output: output.to_string(),
+            })?,
+            exec_main_status,
+        })
+    }
+
+    fn state(&self) -> ActivationState {
+        if self.load_state == "not-found" {
+            return ActivationState::Failed {
+                result: "not-found".to_string(),
+                exit_status: None,
+            };
+        }
+
+        if matches!(self.active_state.as_str(), "activating" | "deactivating") {
+            return ActivationState::Running;
+        }
+
+        // With RemainAfterExit=yes, the unit stays "active" after the process
+        // exits. SubState distinguishes "running" (process alive) from "exited"
+        // (process finished, unit retained for status inspection).
+        if self.active_state == "active" {
+            return if self.sub_state == "exited" {
+                if self.result == "success" {
+                    ActivationState::Succeeded
+                } else {
+                    ActivationState::Failed {
+                        result: self.result.clone(),
+                        exit_status: self.exec_main_status,
+                    }
+                }
+            } else {
+                ActivationState::Running
+            };
+        }
+
+        if self.result == "success" {
+            return ActivationState::Succeeded;
+        }
+
+        ActivationState::Failed {
+            result: self.result.clone(),
+            exit_status: self.exec_main_status,
+        }
+    }
+}
+
 #[async_trait]
 impl Host for Ssh {
     async fn copy_closure(
@@ -102,9 +219,13 @@ impl Host for Ssh {
         }
 
         let activation_command = profile.activation_command(goal).unwrap();
-        let v: Vec<&str> = activation_command.iter().map(|s| &**s).collect();
-        let command = self.ssh(&v);
-        self.run_command(command).await
+        if matches!(goal, Goal::Switch | Goal::Test) {
+            self.activate_detached(&activation_command).await
+        } else {
+            let v: Vec<&str> = activation_command.iter().map(|s| &**s).collect();
+            let command = self.ssh(&v);
+            self.run_command(command).await
