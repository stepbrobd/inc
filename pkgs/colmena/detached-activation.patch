     }
 
     async fn get_current_system_profile(&mut self) -> ColmenaResult<Profile> {
@@ -418,4 +539,242 @@ impl Ssh {
             }
         }
     }
+
+    async fn activate_detached(&mut self, activation_command: &[String]) -> ColmenaResult<()> {
+        let unit = format!("colmena-activate-{}", Uuid::new_v4().simple());
+
+        if let Some(job) = &self.job {
+            job.message("Starting detached activation".to_string())?;
+        }
+
+        match self.start_activation_unit(&unit, activation_command).await {
+            Ok(()) => {}
+            Err(error) if Self::is_connection_loss(&error) => {
+                if let Some(job) = &self.job {
+                    job.message(
+                        "SSH session dropped while activation started; reconnecting to verify"
+                            .to_string(),
+                    )?;
+                }
+            }
+            Err(error) => return Err(error),
+        }
+
+        let deadline = Instant::now() + ACTIVATION_TIMEOUT;
+
+        loop {
+            if Instant::now() >= deadline {
+                return Err(ColmenaError::ActivationTimeout {
+                    hostname: self.host.clone(),
+                    timeout: ACTIVATION_TIMEOUT,
+                });
+            }
+
+            match self.get_activation_status(&unit).await {
+                Ok(status) => match status.state() {
+                    ActivationState::Running => {}
+                    ActivationState::Succeeded => {
+                        self.cleanup_activation_unit(&unit).await;
+                        return Ok(());
+                    }
+                    ActivationState::Failed {
+                        result,
+                        exit_status,
+                    } => {
+                        if result != "not-found" {
+                            self.emit_activation_logs(&unit).await;
+                        }
+                        return Err(ColmenaError::ActivationFailed {
+                            hostname: self.host.clone(),
+                            unit,
+                            result,
+                            exit_status,
+                        });
+                    }
+                },
+                Err(error) if Self::should_retry_activation_status(&error) => {}
+                Err(error) => return Err(error),
+            }
+
+            sleep(Duration::from_secs(2)).await;
+        }
+    }
+
+    async fn start_activation_unit(
+        &mut self,
+        unit: &str,
+        activation_command: &[String],
+    ) -> ColmenaResult<()> {
+        let mut command = vec![
+            "systemd-run".to_string(),
+            "--unit".to_string(),
+            unit.to_string(),
+            "--service-type=exec".to_string(),
+            "--property=RemainAfterExit=yes".to_string(),
+            "--quiet".to_string(),
+            "--".to_string(),
+        ];
+        command.extend(activation_command.iter().cloned());
+
+        let command_refs: Vec<&str> = command.iter().map(String::as_str).collect();
+        self.run_command(self.ssh(&command_refs)).await
+    }
+
+    async fn get_activation_status(&mut self, unit: &str) -> ColmenaResult<ActivationStatus> {
+        let output = self
+            .ssh(&[
+                "systemctl",
+                "show",
+                "--property=LoadState",
+                "--property=ActiveState",
+                "--property=SubState",
+                "--property=Result",
+                "--property=ExecMainStatus",
+                unit,
+            ])
+            .capture_output()
+            .await?;
+
+        ActivationStatus::from_systemctl_show(&output)
+    }
+
+    async fn emit_activation_logs(&mut self, unit: &str) {
+        let Some(job) = &self.job else {
+            return;
+        };
+
+        let logs = self
+            .ssh(&[
+                "journalctl",
+                "-u",
+                unit,
+                "-n",
+                "20",
+                "--no-pager",
+                "-o",
+                "cat",
+            ])
+            .capture_output()
+            .await;
+
+        if let Ok(logs) = logs {
+            for line in logs.lines() {
+                if job.stderr(line.to_string()).is_err() {
+                    break;
+                }
+            }
+        }
+    }
+
+    async fn cleanup_activation_unit(&mut self, unit: &str) {
+        // Stop the unit to release the RemainAfterExit hold, which lets
+        // systemd garbage-collect the transient unit record.
+        let _ = self
+            .ssh(&["systemctl", "stop", unit])
+            .capture_output()
+            .await;
+    }
+
+    fn is_connection_loss(error: &ColmenaError) -> bool {
+        matches!(error, ColmenaError::ChildFailure { exit_code: 255, .. })
+    }
+
+    fn should_retry_activation_status(error: &ColmenaError) -> bool {
+        matches!(
+            error,
+            ColmenaError::IoError { .. }
+                | ColmenaError::ChildFailure { .. }
+                | ColmenaError::ChildKilled { .. }
+        )
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::{ActivationState, ActivationStatus};
+
+    #[test]
+    fn activation_status_parses_successful_unit() {
+        // Unit completed and remains in active/exited due to RemainAfterExit=yes
+        let status = ActivationStatus::from_systemctl_show(
+            "LoadState=loaded\nActiveState=active\nSubState=exited\nResult=success\nExecMainStatus=0\n",
+        )
+        .unwrap();
+
+        assert_eq!(ActivationState::Succeeded, status.state());
+    }
+
+    #[test]
+    fn activation_status_parses_inactive_success() {
+        // Unit in inactive state (e.g. after explicit stop) with success result
+        let status = ActivationStatus::from_systemctl_show(
+            "LoadState=loaded\nActiveState=inactive\nSubState=dead\nResult=success\nExecMainStatus=0\n",
+        )
+        .unwrap();
+
+        assert_eq!(ActivationState::Succeeded, status.state());
+    }
+
+    #[test]
+    fn activation_status_parses_activating_unit() {
+        let status = ActivationStatus::from_systemctl_show(
+            "LoadState=loaded\nActiveState=activating\nSubState=start\nResult=success\nExecMainStatus=0\n",
+        )
+        .unwrap();
+
+        assert_eq!(ActivationState::Running, status.state());
+    }
+
+    #[test]
+    fn activation_status_parses_active_running_unit() {
+        // Process is still running (active/running)
+        let status = ActivationStatus::from_systemctl_show(
+            "LoadState=loaded\nActiveState=active\nSubState=running\nResult=success\nExecMainStatus=0\n",
+        )
+        .unwrap();
+
+        assert_eq!(ActivationState::Running, status.state());
+    }
+
+    #[test]
+    fn activation_status_parses_not_found_unit() {
+        let status = ActivationStatus::from_systemctl_show(
+            "LoadState=not-found\nActiveState=inactive\nSubState=dead\nResult=inactive\nExecMainStatus=0\n",
+        )
+        .unwrap();
+
+        assert_eq!(
+            ActivationState::Failed {
+                result: "not-found".to_string(),
+                exit_status: None,
+            },
+            status.state()
+        );
+    }
+
+    #[test]
+    fn activation_status_handles_trailing_blank_line() {
+        let status = ActivationStatus::from_systemctl_show(
+            "LoadState=loaded\nActiveState=active\nSubState=exited\nResult=success\nExecMainStatus=0\n\n",
+        )
+        .unwrap();
+
+        assert_eq!(ActivationState::Succeeded, status.state());
+    }
+
+    #[test]
+    fn activation_status_parses_failed_unit() {
+        let status = ActivationStatus::from_systemctl_show(
+            "LoadState=loaded\nActiveState=failed\nSubState=failed\nResult=exit-code\nExecMainStatus=1\n",
+        )
+        .unwrap();
+
+        assert_eq!(
+            ActivationState::Failed {
+                result: "exit-code".to_string(),
+                exit_status: Some(1),
+            },
+            status.state()
+        );
+    }
 }
