+
+          This must be set when deploying to darwin nodes with Flakes.
+          For example:
+
+            {
+              inputs.nix-darwin.url = "github:LnL7/nix-darwin";
+              outputs = { nixpkgs, nix-darwin, ... }: {
+                colmena = {
+                  meta.nix-darwin = nix-darwin;
+                  # ...
+                };
+              };
+            }
+        '';
+        type = types.nullOr types.unspecified;
+        default = null;
+      };
     };
   };
 }
